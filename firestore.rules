rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary compatibility rule for the currently deployed frontend.
    // Remove after the Express/Firebase Admin backend is deployed.
    match /settings/restaurant_state {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
