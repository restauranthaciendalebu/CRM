# Firebase web config. Vite exposes only variables prefixed with VITE_.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="restaurant-hacienda.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="restaurant-hacienda"
VITE_FIREBASE_STORAGE_BUCKET="restaurant-hacienda.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="343530480570"
VITE_FIREBASE_APP_ID="1:343530480570:web:395da1eae7b0fb381e7383"
VITE_FIREBASE_MEASUREMENT_ID="G-38DD1TDJ7K"

# Public app URL, used when generating QR links or deployment references.
APP_URL="http://localhost:3000"

# Use the browser Firestore API interceptor instead of the Express backend.
# Keep this false for backend-authoritative mode.
VITE_USE_FIRESTORE_DIRECT_API="false"

# Backend Firestore Admin persistence. Keep credentials outside the repo.
FIRESTORE_ADMIN_ENABLED="false"
FIRESTORE_STATE_DOC_PATH="settings/restaurant_state"
FIREBASE_SERVICE_ACCOUNT_PATH="/absolute/path/to/service-account.json"
